let rtSort = { col: 'apps', asc: false };
let rateFilter = 'all';

function showTab(id, btn) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.section-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('panel-' + id).classList.add('active');
}

function pctBadge(rate) {
  if (rate == null) return '—';
  const cls = rate >= 40 ? 'high' : rate >= 20 ? 'med' : 'low';
  return `<span class="pct-badge ${cls}">${rate.toFixed(1)}%</span>`;
}

function buildTooltip(d) {
  const yrs = d.years || {};
  const labels = ['22-23', '23-24', '24-25'];
  const headers = ['Year', 'Apps', 'Admitted', 'Enrolled'];
  let rows = `<div class="tip-grid">
    <div class="th">${headers[0]}</div><div class="th">${headers[1]}</div><div class="th">${headers[2]}</div><div class="th">${headers[3]}</div>`;
  labels.forEach(yr => {
    const y = yrs[yr];
    if (y) {
      rows += `<div class="yr">${yr}</div><div class="val">${y.apps}</div><div class="val">${y.admitted}</div><div class="val">${y.matric}</div>`;
    } else {
      rows += `<div class="yr">${yr}</div><div class="na">—</div><div class="na">—</div><div class="na">—</div>`;
    }
  });
  rows += `</div>`;
  return `<div class="tooltip"><div class="tooltip-title">Year-by-Year Breakdown</div>${rows}</div>`;
}

function setIndicators(prefix, cols, sortState, defaultCol) {
  cols.forEach(c => {
    const el = document.getElementById(`ind-${prefix}-${c}`);
    if (!el) return;
    const active = c === sortState.col || (sortState.col === 'rank' && c === defaultCol);
    el.textContent = active ? (sortState.asc ? '↑' : '↓') : '';
    el.className = 'sort-ind' + (active ? ' on' : '');
  });
}

function sortData(data, sortState, defaultCol) {
  const col = sortState.col === 'rank' ? defaultCol : sortState.col;
  return [...data].sort((a, b) => {
    const val = d => {
      if (col === 'name') return d.display_name;
      if (col === 'apps') return d.pitt_apps;
      if (col === 'admitted') return d.pitt_admitted;
      if (col === 'matric') return d.pitt_matric;
      if (col === 'pitt_rate') return d.pitt_rate;
      if (col === 'nat_rate') return d.nat_rate;
      if (col === 'diff') return d.pitt_rate - d.nat_rate;
      return 0;
    };
    const av = val(a) ?? -Infinity;
    const bv = val(b) ?? -Infinity;
    if (col === 'name') return sortState.asc ? av.localeCompare(bv) : bv.localeCompare(av);
    return sortState.asc ? av - bv : bv - av;
  });
}

// ── OVERVIEW ──
function sortOverview(col) {
  ovSort = { col, asc: ovSort.col === col ? !ovSort.asc : false };
  renderOverview();
}

function renderOverview() {
  const limit = parseInt(document.getElementById('limit-overview').value);
  const q = document.getElementById('search-overview').value.toLowerCase();
  let data = RAW.filter(d => d.display_name.toLowerCase().includes(q) || d.school.toLowerCase().includes(q));
  data = sortData(data, ovSort, 'apps');
  data = data.slice(0, limit);
  setIndicators('ov', ['rank','name','apps','admitted','matric','pitt_rate'], ovSort, 'apps');

  const totalApps   = RAW.reduce((s,d) => s + d.pitt_apps, 0);
  const totalAdmit  = RAW.reduce((s,d) => s + d.pitt_admitted, 0);
  const totalMatric = RAW.reduce((s,d) => s + d.pitt_matric, 0);
  document.getElementById('stats-overview').innerHTML = `
    <div class="stat-item"><div class="stat-label">Total Applications</div><div class="stat-value">${totalApps.toLocaleString()}</div><div class="stat-sub">across ${RAW.length} law schools</div></div>
    <div class="stat-item"><div class="stat-label">Total Admitted</div><div class="stat-value">${totalAdmit.toLocaleString()}</div><div class="stat-sub">overall admit rate: ${(totalAdmit/totalApps*100).toFixed(1)}%</div></div>
    <div class="stat-item"><div class="stat-label">Total Matriculated</div><div class="stat-value">${totalMatric.toLocaleString()}</div><div class="stat-sub">yield on offers: ${(totalMatric/totalAdmit*100).toFixed(1)}%</div></div>
    <div class="stat-item"><div class="stat-label">Most Applied To</div><div class="stat-value sm">${RAW[0].display_name}</div><div class="stat-sub">${RAW[0].pitt_apps} applications</div></div>`;

  const tbody = document.getElementById('tbody-overview');
  if (!data.length) { tbody.innerHTML = `<tr><td colspan="6" class="no-results">No schools match your search.</td></tr>`; return; }
  tbody.innerHTML = data.map((d, i) => `
    <tr>
      <td class="rank-num">${i+1}</td>
      <td><div class="tip-wrap"><div class="school-name">${d.display_name}</div>${buildTooltip(d)}</div></td>
      <td class="num-cell">${d.pitt_apps}</td>
      <td class="num-cell">${d.pitt_admitted}</td>
      <td class="num-cell">${d.pitt_matric}</td>
      <td>${pctBadge(d.pitt_rate)}</td>
    </tr>`).join('');
}

// ── RATES ──
function setRateFilter(f) {
  rateFilter = f;
  document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
  document.getElementById('chip-' + f).classList.add('active');
  renderRates();
}

function sortRates(col) {
  rtSort = { col, asc: rtSort.col === col ? !rtSort.asc : false };
  renderRates();
}

function renderRates() {
  const limit = parseInt(document.getElementById('limit-rates').value);
  const q = document.getElementById('search-rates').value.toLowerCase();
  let data = RAW.filter(d => d.nat_rate != null && d.pitt_apps >= 15 && d.pitt_admitted > 0);
  data = data.filter(d => d.display_name.toLowerCase().includes(q) || d.school.toLowerCase().includes(q));
  if (rateFilter === 'pos') data = data.filter(d => d.pitt_rate > d.nat_rate);
  if (rateFilter === 'neg') data = data.filter(d => d.pitt_rate <= d.nat_rate);
  data = sortData(data, rtSort, 'apps');
  data = data.slice(0, limit);
  setIndicators('rt', ['rank','name','apps','pitt_rate','nat_rate','diff'], rtSort, 'apps');

  const allR = RAW.filter(d => d.nat_rate != null && d.pitt_apps >= 15 && d.pitt_admitted > 0);
  const aboveAvg  = allR.filter(d => d.pitt_rate > d.nat_rate).length;
  const bigPos    = [...allR].sort((a,b) => (b.pitt_rate-b.nat_rate) - (a.pitt_rate-a.nat_rate))[0];
  const bigNeg    = [...allR].sort((a,b) => (a.pitt_rate-a.nat_rate) - (b.pitt_rate-b.nat_rate))[0];
  const avgDiff   = allR.reduce((s,d) => s + (d.pitt_rate - d.nat_rate), 0) / allR.length;
  document.getElementById('stats-rates').innerHTML = `
    <div class="stat-item"><div class="stat-label">Schools Above Avg</div><div class="stat-value">${aboveAvg}</div><div class="stat-sub">of ${allR.length} schools compared</div></div>
    <div class="stat-item"><div class="stat-label">Biggest Advantage</div><div class="stat-value sm" style="color:var(--positive)">${bigPos.display_name}</div><div class="stat-sub">+${(bigPos.pitt_rate-bigPos.nat_rate).toFixed(1)}% above national</div></div>
    <div class="stat-item"><div class="stat-label">Biggest Gap Below</div><div class="stat-value sm" style="color:var(--negative)">${bigNeg.display_name}</div><div class="stat-sub">${(bigNeg.pitt_rate-bigNeg.nat_rate).toFixed(1)}% below national</div></div>
    <div class="stat-item"><div class="stat-label">Avg Pitt Advantage</div><div class="stat-value">${avgDiff.toFixed(1)}%</div><div class="stat-sub">mean difference vs. national</div></div>`;

  const tbody = document.getElementById('tbody-rates');
  if (!data.length) { tbody.innerHTML = `<tr><td colspan="6" class="no-results">No schools match your filters.</td></tr>`; return; }
  tbody.innerHTML = data.map((d, i) => {
    const diff = d.pitt_rate - d.nat_rate;
    const cls  = diff > 3 ? 'diff-pos' : diff < -3 ? 'diff-neg' : 'diff-neu';
    const txt  = diff > 0 ? `+${diff.toFixed(1)}%` : `${diff.toFixed(1)}%`;
    return `
    <tr>
      <td class="rank-num">${i+1}</td>
      <td><div class="tip-wrap"><div class="school-name">${d.display_name}</div>${buildTooltip(d)}</div></td>
      <td class="num-cell">${d.pitt_apps}</td>
      <td style="font-family:'Roboto Mono',monospace;font-size:13px;font-weight:600;color:var(--pitt-blue)">${d.pitt_rate.toFixed(1)}%</td>
      <td style="font-family:'Roboto Mono',monospace;font-size:13px;color:var(--muted)">${d.nat_rate.toFixed(1)}%</td>
      <td><span class="diff-badge ${cls}">${txt}</span></td>
    </tr>`;
  }).join('');
}

renderOverview();
renderRates();
</script>
</body>
</html>
